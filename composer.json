{
  "name": "madeofpeople/abcnorio-bones",
  "type": "wordpress-plugin",
  "description": "Custom functionality, post types, and taxonomies for ABCNORIO",
  "keywords": [
    "wordpress"
  ],
  "version": "1.0.0",
  "homepage": "https://wpbones.com/",
  "license": "GPL-3.0",
  "authors": [
    {
      "name": "Thiago de Mello Bueno",
      "email": "thiago@madeofpeople.org",
      "homepage": "https://madeofpeople.org/"
    }
  ],
  "support": {
    "issues": "https://github.com/wpbones/WPKirk/issues",
    "source": "https://github.com/wpbones/WPKirk/"
  },
  "require": {
    "php": ">=8.3",
    "wpbones/wpbones": "dev-master",
    "wpbones/wpkirk-helpers": "~2.0"
  },
  "autoload": {
    "psr-4": {
      "WPKirk\\": "plugin/"
    },
    "files": [
      "functions.php"
    ]
  },
  "scripts": {
    "post-autoload-dump": [
      "php -r \"copy('vendor/wpbones/wpbones/src/Console/bin/bones', 'bones');\"",
      "php bones rename --update"
    ]
  }
}
